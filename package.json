{
  "name": "deliberate-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "claude:open": "node scripts/bootstrap-claude-profile.mjs",
    "claude:reload-extension": "node scripts/reload-claude-extension.mjs",
    "chatgpt:open": "node scripts/bootstrap-chatgpt-profile.mjs",
    "chatgpt:reload-extension": "node scripts/reload-chatgpt-extension.mjs",
    "gemini:open": "node scripts/bootstrap-gemini-profile.mjs",
    "gemini:reload-extension": "node scripts/reload-gemini-extension.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:claude": "playwright test tests/e2e/claude-smoke.spec.ts",
    "test:e2e:chatgpt": "playwright test tests/e2e/chatgpt-smoke.spec.ts",
    "test:e2e:local": "playwright test tests/e2e/local-harness.spec.ts",
    "test:e2e:gemini": "playwright test tests/e2e/gemini-smoke.spec.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wxt": "^0.20.0"
  },
  "engines": {
    "node": "24.13.1"
  },
  "volta": {
    "node": "24.13.1"
  }
}
